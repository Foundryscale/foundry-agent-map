      "id": "gs1-query-heatmap",
      "name": "Query Heatmap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1140, 480]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];\nconst result = {};\nrows.forEach(row => {\n  if (!row.created_at || !row.agent_id) return;\n  const d = new Date(row.created_at);\n  const day = dayNames[d.getUTCDay()];\n  const agent = String(row.agent_id).toUpperCase().split('-')[0].slice(0,4);\n  if (!result[agent]) result[agent] = {Mon:0,Tue:0,Wed:0,Thu:0,Fri:0,Sat:0,Sun:0};\n  result[agent][day] = (result[agent][day] || 0) + 1;\n});\nreturn [{ json: { heatmap: result, days: dayNames } }];"
      },
      "id": "gs1-agg-heatmap",
      "name": "Aggregate Heatmap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 480]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://fppuoqteleayiepoykyc.supabase.co/rest/v1/executions?select=agent_id,tokens_used,created_at&created_at=gte.' + encodeURIComponent(new Date(Date.now()-7*86400000).toISOString()) + '&tokens_used=not.is.null&order=created_at.asc' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZwcHVvcXRlbGVheWllcG95a3ljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjI0ODksImV4cCI6MjA4NzQzODQ4OX0.BlTjMTosZIN5poVrjCAuHCaZPt-_S47YfMvxAGlPfs8" },
            { "name": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZwcHVvcXRlbGVheWllcG95a3ljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjI0ODksImV4cCI6MjA4NzQzODQ4OX0.BlTjMTosZIN5poVrjCAuHCaZPt-_S47YfMvxAGlPfs8" }
