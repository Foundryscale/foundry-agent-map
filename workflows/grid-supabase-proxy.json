      "id": "gs1-query-kpis",
      "name": "Query KPIs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1140, 400]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst now = new Date();\nconst todayStr = now.toISOString().slice(0,10);\nconst today = rows.filter(r => r.created_at && r.created_at.startsWith(todayStr));\nconst total = today.length;\nconst successful = today.filter(r => r.success !== false).length;\nconst sr = total > 0 ? Math.round((successful / total) * 1000) / 10 : 0;\nconst f4Execs = today.filter(r => {\n  const aid = String(r.agent_id || '').toUpperCase();\n  return aid.includes('F4') || aid.includes('BYRH');\n}).length;\nreturn [{ json: { execsToday: total, successRate: sr, slackEvents: f4Execs, raw24h: rows.length } }];"
      },
      "id": "gs1-agg-kpis",
      "name": "Aggregate KPIs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://fppuoqteleayiepoykyc.supabase.co/rest/v1/executions?select=agent_id,created_at&created_at=gte.' + encodeURIComponent(new Date(Date.now()-7*86400000).toISOString()) + '&order=created_at.asc' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZwcHVvcXRlbGVheWllcG95a3ljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjI0ODksImV4cCI6MjA4NzQzODQ4OX0.BlTjMTosZIN5poVrjCAuHCaZPt-_S47YfMvxAGlPfs8" },
            { "name": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZwcHVvcXRlbGVheWllcG95a3ljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjI0ODksImV4cCI6MjA4NzQzODQ4OX0.BlTjMTosZIN5poVrjCAuHCaZPt-_S47YfMvxAGlPfs8" }
