        "method": "GET",
        "url": "={{ 'https://fppuoqteleayiepoykyc.supabase.co/rest/v1/executions?select=success,created_at,agent_id&created_at=gte.' + encodeURIComponent(new Date(Date.now()-86400000).toISOString()) + '&order=created_at.desc' }}",
        "sendHeaders": true,
        "headerParameters": {
