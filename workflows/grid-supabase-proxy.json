    {
      "id": "06019f80-69c9-4ed6-b29c-810810ea9934",
      "name": "Agg Heatmap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        380
      ],
      "parameters": {
        "jsCode": "const raw = $json.data || $json.body || '[]';\nconst rows = typeof raw === 'string' ? JSON.parse(raw) : (Array.isArray(raw) ? raw : []);\nconst map = {};\nrows.forEach(r => {\n  const key = (r.agent_id||'unknown') + '|' + (r.created_at||'').slice(0,10);\n  map[key] = (map[key]||0)+1;\n});\nconst heatmap = Object.entries(map).map(([k,v]) => { const [agent_id,day] = k.split('|'); return {agent_id,day,cnt:v}; });\nreturn [{ json: { type: 'heatmap', data: { heatmap }, ts: new Date().toISOString() } }];",
        "mode": "runOnceForAllItems"
      }
    },
