    {
      "id": "3d27a005-0d1d-474e-a644-dfa8e1f1c9de",
      "name": "Agg KPIs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        240
      ],
      "parameters": {
        "jsCode": "const raw = $json.data || $json.body || '[]';\nconst rows = typeof raw === 'string' ? JSON.parse(raw) : (Array.isArray(raw) ? raw : []);\nconst today = new Date().toISOString().slice(0,10);\nconst execsToday = rows.filter(r => r.created_at && r.created_at.startsWith(today)).length;\nconst succ = rows.filter(r => r.success === true || r.success === 'true').length;\nconst successRate = rows.length ? Math.round((succ/rows.length)*1000)/10 : 0;\nconst slackEvents = rows.filter(r => r.agent_id && r.agent_id.toLowerCase().includes('f4') && r.created_at && r.created_at.startsWith(today)).length;\nreturn [{ json: { type: 'kpis', data: { execsToday, successRate, slackEvents }, ts: new Date().toISOString() } }];",
        "mode": "runOnceForAllItems"
      }
    },
    {
