      "id": "gs1-query-cost",
      "name": "Query Cost",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1140, 640]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst now = new Date();\nconst todayStr = now.toISOString().slice(0,10);\nconst today = rows.filter(r => r.created_at && r.created_at.startsWith(todayStr));\nconst tokensToday = today.reduce((sum, r) => sum + (parseInt(r.tokens_used)||0), 0);\nconst tokens7d = rows.reduce((sum, r) => sum + (parseInt(r.tokens_used)||0), 0);\nconst byAgent = {};\ntoday.forEach(r => {\n  const agent = String(r.agent_id||'').toUpperCase().split('-')[0].slice(0,4);\n  byAgent[agent] = (byAgent[agent]||0) + (parseInt(r.tokens_used)||0);\n});\nreturn [{ json: { tokensToday, tokens7d, byAgent } }];"
      },
