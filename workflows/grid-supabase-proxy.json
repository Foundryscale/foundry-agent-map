        "jsCode": "const PROXY_TOKEN = 'gfndr_px_yH7QMB5FwOu9Uu_jT41Y2mcE';\nconst incoming = $json.query?.token || '';\nif (!incoming || incoming !== PROXY_TOKEN) { return [{ json: { __auth_failed: true } }]; }\nconst type = $json.query?.type || 'executions';\nconst limit = Math.min(parseInt($json.query?.limit) || 20, 200);\nreturn [{ json: { ...$json, validated: true, queryType: type, queryLimit: limit } }];",
